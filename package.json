{
  "name": "pco-admin-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "precommit": "lint-staged",
    "orval": "orval",
    "format:write": "prettier --write \"**/*.{js,jsx,mjs,ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{js,jsx,mjs,ts,tsx,mdx}\" --cache",
    "lint:fix": "eslint --fix --ext .ts,.tsx"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --config ./.prettierrc --write -u"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@fontsource/inter": "^5.0.16",
    "@fontsource/plus-jakarta-sans": "^5.0.18",
    "@fontsource/roboto-mono": "^5.0.16",
    "@hookform/resolvers": "^3.3.4",
    "@mui/material": "^5.15.11",
    "@mui/x-date-pickers": "^6.19.6",
    "@phosphor-icons/react": "2.0.15",
    "@reduxjs/toolkit": "^2.1.0",
    "axios": "^1.6.8",
    "dayjs": "^1.11.10",
    "next": "14.1.0",
    "next-auth": "^4.24.7",
    "prettier": "^3.2.4",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.51.0",
    "react-icons": "^5.0.1",
    "react-redux": "^9.1.0",
    "recharts": "^2.12.3",
    "sonner": "^1.4.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "autoprefixer": "^10.0.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.1.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "husky": "^9.0.7",
    "lint-staged": "^15.2.1",
    "orval": "^6.25.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.4.3",
    "typescript-eslint": "^7.3.1"
  }
}
